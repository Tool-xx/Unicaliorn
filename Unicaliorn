local function setActiveButton(buttonName)
    if activeButton == buttonName then return end
    
    -- Сбрасываем предыдущую
    for _, btn in ipairs(sidebarButtons) do
        if btn.Name == activeButton then
            TweenService:Create(btn, TWEEN_HOVER, {BackgroundColor3 = COLORS.Background}):Play()
        end
    end
    
    -- Активируем новую
    for _, btn in ipairs(sidebarButtons) do
        if btn.Name == buttonName then
            TweenService:Create(btn, TWEEN_HOVER, {BackgroundColor3 = COLORS.ButtonActive}):Play()
        end
    end
    
    -- Переключаем контент
    for name, content in pairs(activeContent) do
        if name == buttonName then
            content.Visible = true
            local label = content:FindFirstChild("TextLabel")
            if label then
                TweenService:Create(label, TWEEN_OPEN, {TextTransparency = 0}):Play()
            end
        else
            content.Visible = false
        end
    end
    
    activeButton = buttonName
end

