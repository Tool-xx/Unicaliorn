-- ===== ANTI-AFK =====
local function startAntiAFK()
    if antiAfkRunning then return end
    antiAfkRunning = true
    print("[AntiAFK] Enabled")

    if getconnections then
        pcall(function()
            for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
                if connection.Disable then
                    connection:Disable()
                elseif connection.Disconnect then
                    connection:Disconnect()
                end
            end
        end)
    end

    LocalPlayer.Idled:Connect(function()
        pcall(function()
            local VirtualUser = game:GetService("VirtualUser")
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new(math.random(0,500), math.random(0,500)))
        end)
    end)

    local function CameraMove()
        pcall(function()
            local Camera = workspace.CurrentCamera
            local old = Camera.CFrame
            local angle = math.rad(math.random(-20,20))
            Camera.CFrame = old * CFrame.Angles(0, angle, 0)
        end)
    end

    local function SmallClick()
        pcall(function()
            local VirtualUser = game:GetService("VirtualUser")
            VirtualUser:CaptureController()
            VirtualUser:ClickButton1(Vector2.new(math.random(100,700), math.random(100,500)))
        end)
    end

    local function MicroMove()
        pcall(function()
            local VirtualInputManager = game:GetService("VirtualInputManager")
            local keys = { Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D }
            local key = keys[math.random(1, #keys)]
            VirtualInputManager:SendKeyEvent(true, key, false, game)
            task.wait(math.random(20,50)/100)
            VirtualInputManager:SendKeyEvent(false, key, false, game)
        end)
    end

    antiAfkLoopThread = task.spawn(function()
        while antiAfkRunning do
            local delay = math.random(600, 1500)
            local elapsed = 0
            while antiAfkRunning and elapsed < delay do
                task.wait(1)
                elapsed = elapsed + 1
            end
            if not antiAfkRunning then break end

            local action = math.random(1,100)
            if action <= 50 then
                CameraMove()
            elseif action <= 80 then
                SmallClick()
            else
                MicroMove()
            end
        end
    end)
end

local function stopAntiAFK()
    antiAfkRunning = false
    print("[AntiAFK] Disabled")
    if antiAfkLoopThread then
        task.cancel(antiAfkLoopThread)
        antiAfkLoopThread = nil
    end
end

