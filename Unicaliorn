                local moveConn, releaseConn
                moveConn = UserInputService.InputChanged:Connect(function(input2)
                    if input2.UserInputType == Enum.UserInputType.MouseMovement and dragging then
                        updateFromInput(input2)
                    end
                end)
                releaseConn = UserInputService.InputEnded:Connect(function(input2)
                    if input2.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                        moveConn:Disconnect()
                        releaseConn:Disconnect()
                    end
                end)
            end
        end)
        bg.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                updateFromInput(input)
            end
        end)

        setSlider(value)
        return setSlider
    end

    createRGBSlider("R", 90, r)
    createRGBSlider("G", 125, g)
    createRGBSlider("B", 160, b)

    popup.Destroying:Connect(function()
        if activeColorPicker == popup then activeColorPicker = nil end
    end)

    activeColorPicker = popup
    return popup
end

