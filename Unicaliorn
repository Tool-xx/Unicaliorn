local function toggleSpectate(player)
    if activeSpectatePlayer == player then
        print("[Spectate] Stopped watching " .. player.Name)
        if spectateConnection then spectateConnection:Disconnect() spectateConnection = nil end
        if spectateInputConnection then spectateInputConnection:Disconnect() spectateInputConnection = nil end
        if spectateWheelConnection then spectateWheelConnection:Disconnect() spectateWheelConnection = nil end
        activeSpectatePlayer = nil
        pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
        return false
    else
        print("[Spectate] Watching " .. player.Name)
        if spectateConnection then spectateConnection:Disconnect() end
        if spectateInputConnection then spectateInputConnection:Disconnect() end
        if spectateWheelConnection then spectateWheelConnection:Disconnect() end
        activeSpectatePlayer = player
        local camera = workspace.CurrentCamera
        camera.CameraType = Enum.CameraType.Scriptable

        spectateDistance = 10
        spectateYaw = 0
        spectatePitch = -math.rad(15)

        spectateConnection = RunService.RenderStepped:Connect(function()
            if activeSpectatePlayer and activeSpectatePlayer.Character then
                local root = activeSpectatePlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local offset = CFrame.fromOrientation(spectatePitch, spectateYaw, 0) * Vector3.new(0, 0, spectateDistance)
                    local cameraPos = root.Position + offset
                    local lookAt = root.Position + Vector3.new(0, 3, 0)
                    camera.CFrame = CFrame.lookAt(cameraPos, lookAt)
                end
            end
        end)

        local lastMousePos = UserInputService:GetMouseLocation()
        spectateInputConnection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                if activeSpectatePlayer then
                    local currentPos = UserInputService:GetMouseLocation()
                    local delta = currentPos - lastMousePos
                    lastMousePos = currentPos
                    local sensitivity = 0.3 * (math.rad(1))
                    spectateYaw = spectateYaw - delta.X * sensitivity
                    spectatePitch = math.clamp(spectatePitch - delta.Y * sensitivity, -math.rad(80), math.rad(80))
                end
            end
        end)

        spectateWheelConnection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseWheel then
                if activeSpectatePlayer then
                    spectateDistance = math.clamp(spectateDistance - input.Position.Z * 0.5, 3, 30)
                end
            end
        end)

        return true
    end
end

