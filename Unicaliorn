-- ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
local function getRoot(char)
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then return hum.RootPart end
    end
    return nil
end

-- ===== SPEEDHACK (фикс: RenderStepped loop как в IY) =====
local function toggleSpeedhack(enabled, speed)
    states.speedhack.enabled = enabled
    states.speedhack.speed = speed or states.speedhack.speed
    
    -- Отключаем старые соединения
    if connections.speedhack.loop then
        connections.speedhack.loop:Disconnect()
        connections.speedhack.loop = nil
    end
    if connections.speedhack.charAdded then
        connections.speedhack.charAdded:Disconnect()
        connections.speedhack.charAdded = nil
    end
    
    if enabled then
        local currentSpeed = states.speedhack.speed
        
        local function applySpeed()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = currentSpeed
            end
        end
        
        -- Применяем сразу и каждый кадр (как в IY loopspeed)
        applySpeed()
        
        connections.speedhack.loop = RunService.RenderStepped:Connect(function()
            if states.speedhack.enabled then
                applySpeed()
            end
        end)
        
        -- Обработка респавна
        connections.speedhack.charAdded = LocalPlayer.CharacterAdded:Connect(function(newChar)
            local newHum = newChar:WaitForChild("Humanoid", 10)
            if newHum and states.speedhack.enabled then
                newHum.WalkSpeed = states.speedhack.speed
            end
        end)
    else
        -- Восстанавливаем стандартную скорость
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = 16
        end
    end
end

-- Обновление скорости при изменении слайдера
local function updateSpeedhackSpeed(newSpeed)
    states.speedhack.speed = newSpeed
    if states.speedhack.enabled then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = newSpeed
        end
    end
end

-- ===== FLY (фикс: правильный cleanup + CharacterAdded reconnect) =====
local FLYING = false
local QEfly = true
local CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
local SPEED = 0
local flyKeyDown, flyKeyUp

local function sFLY(flySpeed)
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local T = getRoot(char)
    if not T then return end
    
    -- Отключаем старые соединения ПЕРЕД созданием новых
    if flyKeyDown then flyKeyDown:Disconnect() flyKeyDown = nil end
    if flyKeyUp then flyKeyUp:Disconnect() flyKeyUp = nil end
    
    FLYING = true
    
    -- Создаём физические объекты
    local BG = Instance.new('BodyGyro')
    local BV = Instance.new('BodyVelocity')
    BG.P = 9e4
    BG.Parent = T
    BV.Parent = T
    BG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    BG.CFrame = T.CFrame
    BV.Velocity = Vector3.new(0, 0, 0)
    BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    
    -- Сбрасываем CONTROL перед стартом
    CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
    SPEED = 0
    
    -- Fly loop
    task.spawn(function()
        repeat 
            task.wait()
            local camera = workspace.CurrentCamera
            if humanoid and humanoid.Parent then
                humanoid.PlatformStand = true
            end
            
            local flySpd = flySpeed or states.fly.speed
            local isMoving = CONTROL.L + CONTROL.R ~= 0 or CONTROL.F + CONTROL.B ~= 0 or CONTROL.Q + CONTROL.E ~= 0
            
            if isMoving then
                SPEED = flySpd
            elseif not isMoving and SPEED ~= 0 then
                SPEED = 0
            end
            
            if isMoving then
                BV.Velocity = ((camera.CFrame.LookVector * (CONTROL.F + CONTROL.B)) + 
                    ((camera.CFrame * CFrame.new(CONTROL.L + CONTROL.R, 
                    (CONTROL.F + CONTROL.B + CONTROL.Q + CONTROL.E) * 0.2, 0).p) - camera.CFrame.p)) * SPEED
                lCONTROL = {F = CONTROL.F, B = CONTROL.B, L = CONTROL.L, R = CONTROL.R}
            elseif not isMoving and SPEED ~= 0 then
                BV.Velocity = ((camera.CFrame.LookVector * (lCONTROL.F + lCONTROL.B)) + 
                    ((camera.CFrame * CFrame.new(lCONTROL.L + lCONTROL.R, 
                    (lCONTROL.F + lCONTROL.B + CONTROL.Q + CONTROL.E) * 0.2, 0).p) - camera.CFrame.p)) * SPEED
            else
                BV.Velocity = Vector3.new(0, 0, 0)
            end
            BG.CFrame = camera.CFrame
        until not FLYING
        
        -- Cleanup
        CONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
        lCONTROL = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
        SPEED = 0
        BG:Destroy()
        BV:Destroy()
        if humanoid and humanoid.Parent then 
            humanoid.PlatformStand = false 
        end
    end)
    
    -- Input handlers
    flyKeyDown = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        local flySpd = states.fly.speed
        
        if input.KeyCode == Enum.KeyCode.W then
            CONTROL.F = flySpd
        elseif input.KeyCode == Enum.KeyCode.S then
            CONTROL.B = -flySpd
        elseif input.KeyCode == Enum.KeyCode.A then
            CONTROL.L = -flySpd
        elseif input.KeyCode == Enum.KeyCode.D then
            CONTROL.R = flySpd
        elseif input.KeyCode == Enum.KeyCode.E and QEfly then
            CONTROL.Q = flySpd * 2
        elseif input.KeyCode == Enum.KeyCode.Q and QEfly then
            CONTROL.E = -flySpd * 2
        end
        
        pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Track end)
    end)
    
    flyKeyUp = UserInputService.InputEnded:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.W then
            CONTROL.F = 0
        elseif input.KeyCode == Enum.KeyCode.S then
            CONTROL.B = 0
        elseif input.KeyCode == Enum.KeyCode.A then
            CONTROL.L = 0
        elseif input.KeyCode == Enum.KeyCode.D then
            CONTROL.R = 0
        elseif input.KeyCode == Enum.KeyCode.E then
            CONTROL.Q = 0
        elseif input.KeyCode == Enum.KeyCode.Q then
            CONTROL.E = 0
        end
    end)
end

local function NOFLY()
    FLYING = false
    
    if flyKeyDown then flyKeyDown:Disconnect() flyKeyDown = nil end
    if flyKeyUp then flyKeyUp:Disconnect() flyKeyUp = nil end
    
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass('Humanoid')
        if hum then 
            hum.PlatformStand = false 
        end
    end
    pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
end

local function toggleFly(enabled, speed)
    states.fly.enabled = enabled
    states.fly.speed = speed or states.fly.speed
    
    -- Отключаем старый charAdded если есть
    if connections.fly.charAdded then
        connections.fly.charAdded:Disconnect()
        connections.fly.charAdded = nil
    end
    
    if enabled then
        NOFLY()
        task.wait()
        sFLY(states.fly.speed)
        
        -- РЕКОННЕКТ ПРИ РЕСПАВНЕ (критический фикс!)
        connections.fly.charAdded = LocalPlayer.CharacterAdded:Connect(function(newChar)
            if states.fly.enabled then
                task.wait(0.2) -- дождаться загрузки
                NOFLY()
                task.wait()
                sFLY(states.fly.speed)
            end
        end)
    else
        NOFLY()
    end
end

-- ===== NOCLIP =====
local Noclipping = nil

local function toggleNoclip(enabled)
    states.noclip.enabled = enabled
    
    if Noclipping then
        Noclipping:Disconnect()
        Noclipping = nil
    end
    
    if enabled then
        Noclipping = RunService.Stepped:Connect(function()
            if states.noclip.enabled and LocalPlayer.Character then
                for _, child in pairs(LocalPlayer.Character:GetDescendants()) do
                    if child:IsA("BasePart") and child.CanCollide == true then
                        child.CanCollide = false
                    end
                end
            end
        end)
    else
        if LocalPlayer.Character then
            for _, child in pairs(LocalPlayer.Character:GetDescendants()) do
                if child:IsA("BasePart") and child.Name ~= "HumanoidRootPart" then
                    child.CanCollide = true
                end
            end
        end
    end
end

-- ===== INVISIBLE (GLOBAL) (фикс: упрощённая логика как в IY) =====
local invisRunning = false
local IsInvis = false
local InvisibleCharacter = nil
local Character = nil
local invisFix = nil
local invisDied = nil

local function fixcam()
    NOFLY()
    pcall(function()
        local cam = workspace.CurrentCamera
        if cam then
            cam.CameraType = Enum.CameraType.Custom
            local char = LocalPlayer.Character
            if char then
                cam.CameraSubject = char:FindFirstChildWhichIsA('Humanoid')
            end
        end
    end)
end

local function TurnVisible()
    if IsInvis == false then return end
    
    if invisFix then invisFix:Disconnect() invisFix = nil end
    if invisDied then invisDied:Disconnect() invisDied = nil end
    
    if InvisibleCharacter then
        InvisibleCharacter:Destroy()
        InvisibleCharacter = nil
    end
    
    if Character then
        Character.Parent = workspace
        LocalPlayer.Character = Character
    end
    
    IsInvis = false
    invisRunning = false
    states.invisible.enabled = false
    
    -- Перезапускаем анимации
    pcall(function()
        if Character and Character:FindFirstChild("Animate") then
            Character.Animate.Disabled = true
            task.wait()
            Character.Animate.Disabled = false
        end
    end)
    
    fixcam()
end

function Respawn()
    pcall(function()
        if Character then
            LocalPlayer.Character = Character
            task.wait()
            Character.Parent = workspace
            local hum = Character:FindFirstChildWhichIsA('Humanoid')
            if hum then hum:Destroy() end
        end
        TurnVisible()
    end)
end

local function toggleInvisible(enabled)
    if not enabled then
        if invisRunning then
            TurnVisible()
        end
        return
    end
    
    if invisRunning or IsInvis then return end
    
    invisRunning = true
    states.invisible.enabled = true
    
    local Player = LocalPlayer
    repeat task.wait(0.1) until Player.Character
    Character = Player.Character
    Character.Archivable = true
    
    -- Клонируем ПЕРЕД изменениями
    InvisibleCharacter = Character:Clone()
    InvisibleCharacter.Parent = game:GetService("Lighting")
    InvisibleCharacter.Name = "Invisible_" .. tostring(math.random(1000, 9999))
    
    local Void = workspace.FallenPartsDestroyHeight
    
    -- Void detection
    invisFix = RunService.Stepped:Connect(function()
        pcall(function()
            if not InvisibleCharacter or not InvisibleCharacter.Parent then return end
            local root = InvisibleCharacter:FindFirstChild("HumanoidRootPart")
            if not root then return end
            local Y = root.Position.Y
            if (Void < 0 and Y <= Void) or (Void >= 0 and Y >= Void) then
                Respawn()
            end
        end)
    end)
    
    -- Настраиваем прозрачность клона
    for _, v in pairs(InvisibleCharacter:GetDescendants()) do
        if v:IsA("BasePart") then
            if v.Name == "HumanoidRootPart" then
                v.Transparency = 1
            else
                v.Transparency = 0.5
            end
        end
    end
    
    -- Обработка смерти клона
    local invHum = InvisibleCharacter:FindFirstChildOfClass('Humanoid')
    if invHum then
        invisDied = invHum.Died:Connect(function()
            Respawn()
        end)
    end
    
    IsInvis = true
    
    local CF = workspace.CurrentCamera.CFrame
    local CF_1 = Character.HumanoidRootPart.CFrame
    
    -- Перемещаем оригинал далеко
    Character:MoveTo(Vector3.new(0, math.pi * 1000000, 0))
    task.wait(0.1)
    
    -- Меняем камеру
    workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
    task.wait(0.2)
    workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    
    -- Меняем персонажа
    Character.Parent = game:GetService("Lighting")
    InvisibleCharacter.Parent = workspace
    InvisibleCharacter.HumanoidRootPart.CFrame = CF_1
    Player.Character = InvisibleCharacter
    
    fixcam()
    
    -- Анимации
    pcall(function()
        if InvisibleCharacter:FindFirstChild("Animate") then
            InvisibleCharacter.Animate.Disabled = true
            task.wait()
            InvisibleCharacter.Animate.Disabled = false
        end
    end)
end

