local function enableInfinityJump()
    if infinityJumpEnabled then return end
    infinityJumpEnabled = true
    print("[InfinityJump] Enabled")

    infinityJumpConnection = UserInputService.JumpRequest:Connect(function()
        if not infinityJumpEnabled then return end

        local char = LocalPlayer.Character
        if not char then return end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end

        local root = hum.RootPart
        if not root then return end

        -- Добавляем вертикальную скорость, сохраняя горизонтальную
        local currentVel = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(
            currentVel.X,
            hum.JumpPower,
            currentVel.Z
        )
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end)
end

local function disableInfinityJump()
    if not infinityJumpEnabled then return end
    infinityJumpEnabled = false
    print("[InfinityJump] Disabled")
    if infinityJumpConnection then
        infinityJumpConnection:Disconnect()
        infinityJumpConnection = nil
    end
end
